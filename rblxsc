-- FUNGSI UTAMA (GENDDZ HUB)
local function loadGenddzHub()
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

    local Window = Rayfield:CreateWindow({
        Name = "GENDDZ V1 // ELITE",
        LoadingTitle = "INITIALIZING GENDDZ...",
        LoadingSubtitle = "EST. 2026 | DOMINATE THE SERVER",
        ConfigurationSaving = {Enabled = false}
    })

    -- States & Logic
    local settings = {fly = false, noclip = false, esp = false, healthESP = false, distanceESP = false, tracerESP = false, hitbox = false}
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local player = Players.LocalPlayer

    local PlayerTab = Window:CreateTab("Player", "user")
    local VisualTab = Window:CreateTab("Visuals", "eye")
    local InfoTab = Window:CreateTab("Server Info", "info")

    PlayerTab:CreateToggle({Name = "Fly", Callback = function(v) settings.fly = v end})
    PlayerTab:CreateToggle({Name = "Noclip", Callback = function(v) settings.noclip = v end})
    
    VisualTab:CreateToggle({Name = "ESP Highlight", Callback = function(v) settings.esp = v end})
    VisualTab:CreateToggle({Name = "Health ESP", Callback = function(v) settings.healthESP = v end})
    VisualTab:CreateToggle({Name = "Distance ESP", Callback = function(v) settings.distanceESP = v end})
    VisualTab:CreateToggle({Name = "Tracer ESP", Callback = function(v) settings.tracerESP = v end})
    VisualTab:CreateToggle({Name = "Hitbox Expander", Callback = function(v) settings.hitbox = v end})
    
    local PlayerCountLabel = InfoTab:CreateLabel("Total Players: Loading...")

    local tracers = {}
    
    RunService.Stepped:Connect(function()
        PlayerCountLabel:Set("Total Players: " .. #Players:GetPlayers())
        local char = player.Character
        if char then
            if settings.noclip then for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end end
            if settings.fly then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then root.Velocity = (workspace.CurrentCamera.CFrame.LookVector * (game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.W) and 100 or 0)) end
            end
        end
    end)

    RunService.RenderStepped:Connect(function()
        local camera = workspace.CurrentCamera
        local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local char = p.Character
                local head = char:FindFirstChild("Head")
                local hum = char:FindFirstChild("Humanoid")
                local h = char:FindFirstChild("Highlight")
                
                if settings.esp and not h then Instance.new("Highlight", char) elseif not settings.esp and h then h:Destroy() end
                
                local hp = head and head:FindFirstChild("HP_ESP")
                if (settings.healthESP or settings.distanceESP) and head then
                    if not hp then
                        local bg = Instance.new("BillboardGui", head); bg.Name = "HP_ESP"; bg.Size = UDim2.new(0, 100, 0, 30); bg.AlwaysOnTop = true
                        local barBg = Instance.new("Frame", bg); barBg.Size = UDim2.new(1, 0, 0, 5); barBg.Position = UDim2.new(0, 0, 0.8, 0); barBg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                        local bar = Instance.new("Frame", barBg); bar.Name = "Bar"; bar.Size = UDim2.new(1, 0, 1, 0); bar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                        local txt = Instance.new("TextLabel", bg); txt.Name = "Text"; txt.Size = UDim2.new(1, 0, 1, 0); txt.BackgroundTransparency = 1; txt.TextColor3 = Color3.new(1, 1, 1); txt.Font = Enum.Font.GothamBold; txt.TextScaled = true
                    end
                    
                    local distText = ""
                    if settings.distanceESP and myRoot and char:FindFirstChild("HumanoidRootPart") then
                        local dist = math.floor((myRoot.Position - char.HumanoidRootPart.Position).Magnitude)
                        distText = " | " .. dist .. "m"
                    end
                    
                    local health = hum and hum.Health or 0; local maxHealth = hum and hum.MaxHealth or 100
                    head.HP_ESP.Text.Text = (settings.healthESP and "HP: " .. math.floor(health) or "") .. distText
                    head.HP_ESP.Frame.Bar.Size = UDim2.new(health/maxHealth, 0, 1, 0)
                    head.HP_ESP.Frame.Bar.BackgroundColor3 = Color3.fromRGB(255 - (health/maxHealth*255), (health/maxHealth*255), 0)
                elseif hp then hp:Destroy() end
                
                if hum and hum.Health > 0 then
                    if settings.hitbox and head then head.Size = Vector3.new(6,6,6); head.Transparency = 0.5; head.CanCollide = false elseif head then head.Size = Vector3.new(1,1,1); head.Transparency = 0 end
                    if settings.tracerESP and head then
                        if not tracers[p] and typeof(Drawing) == "table" then tracers[p] = Drawing.new("Line"); tracers[p].Color = Color3.new(1,0,0) end
                        if tracers[p] then
                            local pos, on = camera:WorldToViewportPoint(head.Position)
                            if on then tracers[p].Visible = true; tracers[p].From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y); tracers[p].To = Vector2.new(pos.X, pos.Y) else tracers[p].Visible = false end
                        end
                    elseif tracers[p] then tracers[p].Visible = false end
                end
            end
        end
    end)
    Rayfield:Notify({Title = "GENDDZ V1 // ELITE", Content = "Login Berhasil! Selamat beraksi.", Duration = 3})
end

-- LOGIN EVENT
SubmitBtn.MouseButton1Click:Connect(function()
    local success, response = pcall(function() return game:HttpGet(PASSWORD_URL) end)
    if success then
        local realKey = string.gsub(response, "%s+", "")
        if TextBox.Text == realKey then
            ScreenGui:Destroy()
            loadGenddzHub()
        else
            SubmitBtn.Text = "WRONG KEY!"; task.wait(1); SubmitBtn.Text = "AUTHENTICATE"
        end
    else
        SubmitBtn.Text = "SERVER ERROR!"; task.wait(1); SubmitBtn.Text = "AUTHENTICATE"
    end
end)
